# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=sams/sensors
MQTT_CLIENT_ID=sams-gateway

# Cloud
CLOUD_API_URL=http://localhost:8000
CLOUD_API_KEY=dev-secret-key-change-in-prod
DATABASE_URL=sqlite+aiosqlite:///./sams.db

# Weather API
WEATHER_API_KEY=your_openweathermap_key_here
WEATHER_CITY=Bengaluru
WEATHER_MODE=mock           
WEATHER_CACHE_TTL=1800 

SENSOR_PUBLISH_INTERVAL=5 
SENSOR_NODE_COUNT=4
SENSOR_NOISE_FACTOR=0.05

# ML 
ML_MODEL_TYPE=rf            # rf | torch
ML_MODEL_PATH=ml_engine/models
ML_CONFIDENCE_THRESHOLD=0.65

# Decision Engine
COOLDOWN_MINUTES=15
RAIN_PROBABILITY_THRESHOLD=0.6
ANOMALY_ZSCORE_THRESHOLD=3.0

# Pump Controller
PUMP_MAX_RUNTIME_SECONDS=600
PUMP_SAFETY_TIMEOUT_SECONDS=900

# Scheduler
CYCLE_DELAY_SECONDS=30

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=development
